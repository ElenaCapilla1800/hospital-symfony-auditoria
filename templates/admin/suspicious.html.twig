{% extends 'base.html.twig' %}

{% block title %}ALERTA: Accesos Sospechosos{% endblock %}

{% block body %}
<div class="container-fluid">
    {# Cabecera de Alerta Crítica #}
    <div class="alert alert-danger d-flex align-items-center shadow-sm mb-4 border-0" role="alert">
        <i class="bi bi-shield-slash-fill fs-1 me-3"></i>
        <div>
            <h4 class="alert-heading mb-1 fw-bold">Informe de Actividad Sospechosa</h4>
            <p class="mb-0">Mostrando exclusivamente intentos de acceso <strong>denegados</strong> en las últimas <strong>24 horas</strong>.</p>
        </div>
    </div>

    {# Tarjeta de Incidentes #}
    <div class="card shadow-sm border-danger">
        <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center py-3">
            <h6 class="m-0 fw-bold"><i class="bi bi-exclamation-triangle me-2"></i>Logs de Seguridad Recientes</h6>
            <span class="badge bg-white text-danger">{{ logs|length }} incidentes detectados</span>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-secondary small text-uppercase">
                    <tr>
                        <th class="ps-4">Momento</th>
                        <th>Usuario Implicado</th>
                        <th>Acción Bloqueada</th>
                        <th>Dirección IP</th>
                        <th class="text-end pe-4">Estado</th>
                    </tr>
                </thead>
                <tbody>
                    {% for log in logs %}
                        <tr class="table-warning"> {# Resaltado en amarillo para indicar precaución #}
                            <td class="ps-4">
                                <div class="fw-bold text-dark">{{ log.createdAt|date('H:i:s') }}</div>
                                <small class="text-muted">{{ log.createdAt|date('d/m/Y') }}</small>
                            </td>
                            <td>
                                <span class="badge bg-dark px-2 py-1">{{ log.user.email }}</span>
                            </td>
                            <td>
                                <code class="text-danger fw-bold bg-light p-1 rounded">{{ log.action }}</code>
                            </td>
                            <td>
                                <span class="text-monospace small">{{ log.ipAddress }}</span>
                            </td>
                            <td class="text-end pe-4">
                                <span class="badge bg-danger">
                                    <i class="bi bi-x-circle me-1"></i> DENEGADO
                                </span>
                            </td>
                        </tr>
                    {% else %}
                        {# Caso en el que no haya intentos fallidos #}
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <div class="text-success mb-3">
                                    <i class="bi bi-check-circle-fill display-4"></i>
                                </div>
                                <h5 class="text-dark">No se han detectado amenazas</h5>
                                <p class="text-muted mb-0">El sistema no registra accesos denegados en las últimas 24 horas.</p>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <div class="card-footer bg-light py-3">
            <a href="{{ path('app_admin_logs') }}" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left"></i> Volver a la Auditoría General
            </a>
        </div>
    </div>
</div>
{% endblock %}
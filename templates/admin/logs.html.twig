{% extends 'base.html.twig' %}

{% block title %}Auditoría General{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 text-primary mb-0"><i class="bi bi-list-check"></i> Registro de Auditoría</h1>
        <span class="badge bg-secondary">{{ logs|length }} registros encontrados</span>
    </div>

    {# --- BLOQUE DE FILTROS (Punto 19) --- #}
    <div class="card shadow-sm mb-4 border-0 bg-light">
        <div class="card-body">
            <form method="get" class="row g-3">
                {# Filtro por Email #}
                <div class="col-md-3">
                    <label class="small fw-bold text-muted">Email del Usuario</label>
                    <input type="text" name="email" class="form-control form-control-sm"
                            placeholder="Buscar por email..." value="{{ currentEmail }}">
                </div>

                {# Filtro por Acción #}
                <div class="col-md-3">
                    <label class="small fw-bold text-muted">Acción</label>
                    <select name="action" class="form-select form-select-sm">
                        <option value="">-- Todas las acciones --</option>
                        <option value="RECORD_VIEW" {% if currentAction == 'RECORD_VIEW' %}selected{% endif %}>Ver Historial</option>
                        <option value="RECORD_EDIT" {% if currentAction == 'RECORD_EDIT' %}selected{% endif %}>Editar Historial</option>
                    </select>
                </div>

                {# Filtro por Fecha (Añadido para completar el Punto 19) #}
                <div class="col-md-3">
                    <label class="small fw-bold text-muted">Fecha específica</label>
                    <input type="date" name="date" class="form-control form-control-sm" value="{{ currentDate }}">
                </div>

                {# Botones de acción #}
                <div class="col-md-3 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-primary btn-sm flex-grow-1">
                        <i class="bi bi-funnel"></i> Aplicar Filtros
                    </button>
                    <a href="{{ path('app_admin_logs') }}" class="btn btn-outline-secondary btn-sm" title="Limpiar">
                        <i class="bi bi-arrow-counterclockwise"></i>
                    </a>
                </div>
            </form>
        </div>
    </div>

    {# --- TABLA DE RESULTADOS (Punto 18) --- #}
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle bg-white mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4">Fecha y Hora</th>
                    <th>Usuario</th>
                    <th>Acción Realizada</th>
                    <th>IP Origen</th>
                    <th>Estado de Acceso</th>
                </tr>
            </thead>
            <tbody>
                {% for log in logs %}
                    {# Resaltamos en rojo las filas donde el acceso fue denegado #}
                    <tr class="{{ not log.granted ? 'table-danger' : '' }}">
                        <td class="ps-4">
                            <span class="text-dark fw-bold">{{ log.createdAt|date('d/m/Y') }}</span>
                            <small class="text-muted d-block">{{ log.createdAt|date('H:i:s') }}</small>
                        </td>
                        <td>
                            <div class="d-flex align-items-center">
                                <i class="bi bi-person-circle me-2 text-secondary"></i>
                                {{ log.user.email }}
                            </div>
                        </td>
                        <td>
                            <span class="badge border text-dark bg-light font-monospace">
                                {{ log.action }}
                            </span>
                        </td>
                        <td>
                            <small class="text-muted">{{ log.ipAddress }}</small>
                        </td>
                        <td>
                            {% if log.granted %}
                                <span class="text-success small fw-bold">
                                    <i class="bi bi-check-circle-fill"></i> PERMITIDO
                                </span>
                            {% else %}
                                <span class="text-danger small fw-bold">
                                    <i class="bi bi-shield-lock-fill"></i> DENEGADO
                                </span>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center py-5">
                            <i class="bi bi-search display-4 text-light"></i>
                            <p class="text-muted mt-2">No se encontraron registros con los filtros seleccionados.</p>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
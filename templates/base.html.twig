<!DOCTYPE html>
<html lang="es">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Hospital Symfony{% endblock %}</title>

        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2290%22>🏥</text></svg>">

        {# Bootstrap 5 y Iconos #}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

        <style>
            body { background-color: #f4f7f6; }
            .navbar-brand { font-weight: 800; letter-spacing: -1px; }
            .main-container { background: white; border-radius: 8px; padding: 2rem; box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075); margin-top: 2rem; }
        </style>

        {% block stylesheets %}{% endblock %}
    </head>
    <body>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
            <div class="container">
                <a class="navbar-brand" href="{{ path('app_home') }}">
                    <i class="bi bi-hospital"></i> HOSPITAL SYMFONY
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        {% if is_granted('ROLE_DOCTOR') %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_medical_record_index') }}">
                                    <i class="bi bi-file-medical"></i> Historiales
                                </a>
                            </li>
                        {% endif %}

                        {# --- NAVEGACIÓN DE ADMINISTRADOR (Puntos 19 y 24) --- #}
                        {% if is_granted('ROLE_ADMIN') %}
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle fw-bold text-warning" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-shield-lock"></i> Panel de Control
                                </a>
                                <ul class="dropdown-menu">
                                    {# Enlace a la Auditoría General (Tu método viewLogs) #}
                                    <li>
                                        <a class="dropdown-item" href="{{ path('app_admin_logs') }}">
                                            <i class="bi bi-list-check text-primary"></i> Registro de Auditoría
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    {# Enlace al Informe de Sospechosos (Tu método suspiciousReport) #}
                                    <li>
                                        <a class="dropdown-item text-danger" href="{{ path('app_admin_suspicious') }}">
                                            <i class="bi bi-exclamation-triangle-fill"></i> Intentos Sospechosos (24h)
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        {% endif %}
                    </ul>

                    {# SECCIÓN DE USUARIO #}
                    <div class="d-flex align-items-center">
                        {% if app.user %}
                            <div class="text-light me-3 small">
                                <strong>{{ app.user.userIdentifier }}</strong>
                                <span class="badge {{ is_granted('ROLE_ADMIN') ? 'bg-danger' : 'bg-info text-dark' }} ms-1">
                                    {{ is_granted('ROLE_ADMIN') ? 'Admin' : 'Médico' }}
                                </span>
                            </div>
                            <a href="{{ path('app_logout') }}" class="btn btn-outline-light btn-sm">Salir</a>
                        {% else %}
                            <a href="{{ path('app_login') }}" class="btn btn-light btn-sm fw-bold">Iniciar Sesión</a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </nav>

        {# Mensajes Flash #}
        <div class="container mt-3">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'success' ? 'success' : 'danger' }} alert-dismissible fade show shadow-sm" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}
            {% endfor %}
        </div>

        <main class="container">
            <div class="main-container">
                {% block body %}{% endblock %}
            </div>
        </main>

        <footer class="container text-center text-muted my-5 small">
            <hr>
            &copy; {{ "now"|date("Y") }} Hospital Symfony - Gestión Médica Profesional
        </footer>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        {% block javascripts %}{% endblock %}
    </body>
</html>